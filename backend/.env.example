# ==================================
# CONFIGURACIÓN DE BASE DE DATOS
# ==================================
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=tu_contraseña
DB_NAME=erp_psi
DB_PORT=3306

# ==================================
# CONFIGURACIÓN DEL SERVIDOR
# ==================================
PORT=3001
NODE_ENV=development

# ==================================
# CONFIGURACIÓN DE SEGURIDAD
# ==================================
JWT_SECRET=tu_clave_secreta_jwt_aqui
SESSION_SECRET=tu_clave_secreta_sesion_aqui

# ==================================
# CONFIGURACIÓN DE EMAIL (smtp.com Email API)
# Documentación: https://www.smtp.com/email-api/
# ==================================

# API Key generada en tu panel smtp.com → Settings → API Keys
SMTPCOM_API_KEY=tu_api_key_de_smtpcom

# Nombre del canal (sender channel) configurado en tu cuenta smtp.com
# Panel smtp.com → Senders → Channels
SMTPCOM_CHANNEL=nombre_de_tu_canal

# Dirección de correo del remitente (debe estar verificada en smtp.com)
SMTPCOM_FROM_EMAIL=notificaciones@psi.com
SMTPCOM_FROM_NAME=PSI Telecomunicaciones

# Emails de administradores (separados por comas) — reciben alertas del sistema
EMAIL_ADMIN=admin@psi.com,soporte@psi.com

# ==================================
# CONFIGURACIÓN DE ARCHIVOS
# ==================================
UPLOAD_DIR=uploads
TEMP_DIR=temp

# ==================================
# CONFIGURACIÓN DE LOGS
# ==================================
LOG_LEVEL=info
LOG_FILE=logs/app.log

# ==================================
# OTRAS CONFIGURACIONES
# ==================================
# Tiempo de expiración de tokens (en horas)
TOKEN_EXPIRATION=24

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# ==================================
# CONFIGURACIÓN SMS — LABSMOBILE
# ==================================
# Regístrate en https://www.labsmobile.com y obtén tus credenciales API
LABSMOBILE_USER=tu_email@labsmobile.com
LABSMOBILE_TOKEN=tu_token_api_labsmobile
# Número remitente (opcional — usa el del plan si se deja vacío)
# LABSMOBILE_SENDER=573001234567

# Teléfono de la empresa (se incluye en SMS de notificación)
EMPRESA_TELEFONO=3001234567

# ==================================
# CONFIGURACIÓN PUSH NOTIFICATIONS (VAPID)
# ==================================
# Genera las claves desde el panel Configuración > Notificaciones Push
# o ejecuta en backend: node -e "const wp=require('web-push'); console.log(wp.generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Debe ser una URL o mailto: válido
VAPID_SUBJECT=mailto:admin@psi.com

# ==================================
# CONFIGURACIÓN DE IA (GROQ + LLAMA 3.3)
# ==================================
# Obtén tu API key gratuita en: https://console.groq.com/keys
# Modelo usado: llama-3.3-70b-versatile
# Free tier: ~30 req/min, 14,400 req/día, latencia ~250ms
# Sin esta key, el chatbot usará respuestas predefinidas (funciona igual)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# ==================================
# NOTAS DE CONFIGURACIÓN — smtp.com
# ==================================
#
# Pasos para configurar smtp.com:
# 1. Crea una cuenta en https://www.smtp.com
# 2. En el panel ve a Settings → API Keys → Crear nueva API Key
#    Copia el valor en SMTPCOM_API_KEY
# 3. En el panel ve a Senders → Channels → Crear o seleccionar un canal
#    El nombre del canal va en SMTPCOM_CHANNEL
# 4. Verifica tu dominio/email en Senders → Verified Senders
#    Ese email va en SMTPCOM_FROM_EMAIL
